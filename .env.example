# GitHub Token for extending Rate Limit (Optional)
GITHUB_TOKEN=

# LLM Configuration (Optional, fallback to Ollama if empty)
# Use 'local-fallback' for local LLMs, or your specific provider KEY
LLM_API_KEY=

# Local or Remote LLM URL (Ollama example: http://127.0.0.1:11434/v1)
LLM_BASE_URL=

# Model Name (e.g., gpt-4o-mini, llama3, deepseek-chat)
LLM_MODEL=

# Batch Sizes
BATCH_SIZE=5
DISCOVER_BATCH_SIZE=50
EVALUATE_BATCH_SIZE=10

# Loop script settings (in seconds, default: 60)
LOOP_INTERVAL_SECONDS=60

# Topic Discovery & Exploration Settings
MAX_PAGES_DEFAULT=5
MAX_PAGES_QUALITY=20
QUALITY_TOPIC_THRESHOLD=5
AUTO_FETCH_DESC_STARS=1000
